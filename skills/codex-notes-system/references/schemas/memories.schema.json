{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Notes Memories",
  "type": "object",
  "required": ["last_updated", "preferences", "workflow"],
  "properties": {
    "version": {
      "type": "string"
    },
    "last_updated": {
      "type": "string",
      "format": "date-time"
    },
    "preferences": {
      "type": "object",
      "required": ["response_style", "examples", "emoji"],
      "properties": {
        "response_style": {
          "type": "string",
          "enum": ["concise", "detailed", "step_by_step"]
        },
        "examples": {
          "type": "string",
          "enum": ["never", "only_when_requested", "often", "always"]
        },
        "emoji": {
          "type": "string",
          "enum": ["never", "allowed", "preferred"]
        },
        "technical_level": {
          "type": "string",
          "enum": ["beginner", "intermediate", "advanced"]
        }
      },
      "additionalProperties": false
    },
    "workflow": {
      "type": "object",
      "required": ["prefer_scripts", "prefer_json_edits", "testing_required", "version_control"],
      "properties": {
        "prefer_scripts": {
          "type": "boolean"
        },
        "prefer_json_edits": {
          "type": "boolean"
        },
        "testing_required": {
          "type": "boolean"
        },
        "version_control": {
          "type": "string",
          "enum": ["minimal", "active", "strict"]
        }
      },
      "additionalProperties": false
    },
    "projects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "notes"],
        "properties": {
          "name": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
