# Copy to .env and fill in values. Never commit .env.

# GitHub (for push/auth — use anonymous email or fine-grained token)
# https://docs.github.com/en/account-and-profile/setting-up-and-managing-your-github-profile/managing-your-profile-readme/setting-your-commit-email-address
GITHUB_EMAIL=
GITHUB_TOKEN=

# Optional: API keys for toolkit services
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# DEEPSEEK_API_KEY=
# KAGGLE_USERNAME=
# KAGGLE_KEY=
