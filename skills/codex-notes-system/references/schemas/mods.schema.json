{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Notes Mods",
  "type": "object",
  "required": ["version", "precedence", "defaults", "user", "project", "hard", "effective"],
  "properties": {
    "version": {
      "type": "string"
    },
    "precedence": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["hard", "project", "user", "default"]
      }
    },
    "defaults": {
      "$ref": "#/$defs/modsLayer"
    },
    "user": {
      "$ref": "#/$defs/modsLayer"
    },
    "project": {
      "$ref": "#/$defs/modsLayer"
    },
    "hard": {
      "$ref": "#/$defs/modsLayer"
    },
    "effective": {
      "$ref": "#/$defs/modsLayer"
    }
  },
  "$defs": {
    "modsLayer": {
      "type": "object",
      "properties": {
        "response_style": {
          "type": "string",
          "enum": ["concise", "detailed", "step_by_step"]
        },
        "examples": {
          "type": "string",
          "enum": ["never", "only_when_requested", "often", "always"]
        },
        "emoji": {
          "type": "string",
          "enum": ["never", "allowed", "preferred"]
        },
        "comment_style": {
          "type": "string",
          "enum": ["minimal", "descriptive", "none"]
        },
        "spacing": {
          "type": "string",
          "enum": ["minimal", "liberal"]
        },
        "paradigm": {
          "type": "string",
          "enum": ["functional", "object_oriented", "procedural", "mixed"]
        },
        "testing_required": {
          "type": "boolean"
        },
        "version_control": {
          "type": "string",
          "enum": ["minimal", "active", "strict"]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
