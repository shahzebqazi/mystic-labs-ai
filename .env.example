# Copy to `.env` and adjust (`.env` is gitignored).
# Mystic AI Labs — local development and harness defaults.

# OpenAI-compatible API (e.g. llama-server from Orchestration/orchestrator-compose.yml)
MODEL_ENDPOINT=http://localhost:8080

# Headless harness (Orchestration/Harness/*.py)
HEADLESS_BASE_URL=http://localhost:8080
HEADLESS_MODEL=default

# Lua GUI → Python harness (Orchestration/Harness/lua_gui/)
HARNESS_URL=http://127.0.0.1:15555

# Mockups Vite base path: `/` for local dev; GitHub Pages uses `/mystic-ai-labs/mockups/` in CI
# BASE_PATH=/
